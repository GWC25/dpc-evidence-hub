  "webParts": {
    "date": { "type": "date", "label": "Date", "required": true },
    "title": { "type": "text", "label": "Title / Summary", "required": true, "hasMic": true },
    "peoplePicker": { "type": "select", "label": "People", "multiple": true, "linkedTo": "peopleRegistry" },
    "attendeesTable": { "type": "table", "label": "Attendees", "columns": ["name", "role"] },
