    "previousNotes": { "type": "lockedText", "label": "Previous Notes (read-only)", "autofill": true },
    "actionPoints": { "type": "structuredList", "label": "Action Points", "fields": ["action", "deadline", "who", "howSupport"] },
    "reviewDate": { "type": "date", "label": "Review Date", "optional": true },
    "moodSliders": { "type": "sliders", "label": "Mood & Stress", "scales": ["mood", "stress", "confidence"] },
    "coachingPrompt": { "type": "textarea", "label": "Coaching Question / Prompt", "hasMic": true, "optional": true },
    "reflectionNotes": { "type": "textarea", "label": "Reflection", "hasMic": true, "optional": true },
    "resourceLinks": { "type": "resourcePicker", "label": "Resources Used", "multiple": true, "linkedTo": "resourceLibrary" },
    "planningNotes": { "type": "textarea", "label": "Planning for Next Session", "hasMic": true, "optional": true },
    "tags": { "type": "tagPicker", "label": "Tags", "linkedTo": "commonPurposes", "threeTier": true },
    "threadLinker": { "type": "select", "label": "Link to Thread", "linkedTo": "threads", "optional": true, "allowNew": true },
    "evidenceLinks": { "type": "linkPicker", "label": "Evidence Links", "multiple": true, "optional": true },
    "provider": { "type": "text", "label": "Provider / Organisation" },
    "duration": { "type": "text", "label": "Duration" },
    "learningTakeaway": { "type": "textarea", "label": "Key Learning Takeaway", "hasMic": true },
    "applicationPlan": { "type": "textarea", "label": "How You'll Apply This", "hasMic": true, "optional": true },
    "location": { "type": "text", "label": "Location / Event" },
    "eventType": { "type": "select", "label": "Event Type", "options": ["Conference", "Workshop", "Networking", "Training", "Other"] },
    "attendees": { "type": "text", "label": "Who Attended" },
    "networkingNotes": { "type": "textarea", "label": "Networking Notes & Contacts", "hasMic": true, "optional": true },
    "cogsTheme": { "type": "select", "label": "COGs Theme", "linkedTo": "cogsThemes" },
    "objectives": { "type": "textarea", "label": "Objectives / Learning Outcomes", "hasMic": true },
    "targetAudience": { "type": "text", "label": "Target Audience" },
    "resources": { "type": "resourcePicker", "label": "Resources", "multiple": true, "linkedTo": "resourceLibrary", "optional": true },
    "learningOutcomes": { "type": "textarea", "label": "Expected Learning Outcomes", "hasMic": true },
    "sessionNumber": { "type": "hidden", "value": "auto-populated" },
    "sessionPlan": { "type": "textarea", "label": "Session Plan & Delivery Notes", "hasMic": true },
    "attendeeCount": { "type": "number", "label": "Number of Attendees" }
